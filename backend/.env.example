# Backend
DATABASE_URL=postgresql+asyncpg://codereview:password@localhost:5432/codereview
REDIS_URL=redis://localhost:6379/0

# AI Providers (set at least one)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_AI_PROVIDER=openai   # openai | anthropic

# GitHub Integration
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_INSTALLATION_ID=

# GitLab Integration
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=your-gitlab-webhook-secret

# Slack Integration
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXXX

# App settings
SECRET_KEY=change-me-in-production-32chars-min
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
ENVIRONMENT=development
